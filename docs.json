{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Provar Trust AI",
  "colors": {
    "primary": "#5E6AD2",
    "light": "#828FFF",
    "dark": "#4651B8"
  },
  "background": {
    "colors": {
      "light": "#FCFCFB",
      "dark": "#08090A"
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/provar-logo.svg",
    "dark": "/logo/provar-logo.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          { "group": "Welcome",   "icon": "sparkles",       "pages": ["index"] },
          { "group": "Concepts",  "icon": "book-open",      "pages": ["concepts/overview", "concepts/projects", "concepts/sessions", "concepts/annotations", "concepts/datasets", "concepts/evaluators", "concepts/evaluations", "concepts/evaluation-loop"] },
          { "group": "Tutorials", "icon": "graduation-cap", "pages": ["tutorials/quickstart"] },
          { "group": "How-to",    "icon": "wrench",         "pages": ["how-to/connect-agentcore"] },
          { "group": "Resources", "icon": "bookmark",       "pages": ["glossary", "changelog"] }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json"
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  }
}
