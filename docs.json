{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Provar Trust AI",
  "colors": {
    "primary": "#5E6AD2",
    "light": "#828FFF",
    "dark": "#4651B8"
  },
  "background": {
    "colors": {
      "light": "#FCFCFC",
      "dark": "#08090A"
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/provar-logo-light.png",
    "dark": "/logo/provar-logo-dark.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          { "group": "Welcome",   "icon": "house",                "pages": ["index"] },
          { "group": "Concepts",  "icon": "lightbulb",            "pages": ["concepts/overview", "concepts/evaluation-loop"] },
          { "group": "Tutorials", "icon": "graduation-cap",       "pages": ["tutorials/quickstart"] },
          { "group": "How-to",    "icon": "screwdriver-wrench",   "pages": ["how-to/connect-agentcore"] },
          { "group": "Reference", "icon": "book",                 "pages": ["reference/api", "reference/schemas"] },
          { "group": "Resources", "icon": "folder-open",          "pages": ["glossary", "changelog"] }
        ]
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  }
}
