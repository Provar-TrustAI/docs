{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Provar Trust AI",
  "colors": {
    "primary": "#5E6AD2",
    "light": "#828FFF",
    "dark": "#4651B8"
  },
  "background": {
    "colors": {
      "light": "#FCFCFC",
      "dark": "#08090A"
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600,
      "source": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    },
    "body": {
      "family": "Inter",
      "weight": 400,
      "source": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/provar-logo-light.png",
    "dark": "/logo/provar-logo-dark.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          { "group": "Welcome",   "pages": ["index"] },
          { "group": "Concepts",  "pages": ["concepts/overview", "concepts/evaluation-loop"] },
          { "group": "Tutorials", "pages": ["tutorials/quickstart"] },
          { "group": "How-to",    "pages": ["how-to/connect-agentcore"] },
          { "group": "Reference", "pages": ["reference/api", "reference/schemas"] },
          { "group": "Resources", "pages": ["glossary", "changelog"] }
        ]
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  }
}
